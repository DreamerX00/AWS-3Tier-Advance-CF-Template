# ========================================
# AWS Practice App — Environment Variables
# ========================================

# PostgreSQL Configuration
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=awspractice
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Backend Configuration
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost:3000

# Frontend Configuration (empty = use nginx proxy /api → backend:8080)
VITE_API_URL=

# Runtime proxy target for the production nginx container
API_UPSTREAM=http://backend:8080

# Object storage defaults for local MinIO and production S3
STORAGE_BUCKET_NAME=aws-practice-storage
S3_PATH_STYLE=true
